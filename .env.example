# Copie este arquivo para .env e preencha com valores reais.
# NUNCA commitar o arquivo .env com valores reais.

# Postgres local (Docker Compose) — role "owner", só usada para criar as
# roles de runtime e rodar migrations (prisma migrate). Nunca usada pela
# API em tempo de execução.
POSTGRES_SUPERUSER="aet_hub_owner"
POSTGRES_SUPERUSER_PASSWORD="defina-uma-senha-forte-aqui"
POSTGRES_DB="aet_hub"

# Senhas das roles de runtime (ver apps/api/prisma/roles.sql). São usadas
# para montar AUTH_DATABASE_URL/DATABASE_URL abaixo e para rodar
# `npm run db:roles --workspace apps/api`.
AET_APP_DB_PASSWORD="defina-uma-senha-forte-aqui"
AET_AUTH_DB_PASSWORD="defina-uma-senha-forte-aqui"

# Banco de dados (PostgreSQL)
# - MIGRATE_DATABASE_URL: role owner/superuser, só para `prisma migrate`.
# - DATABASE_URL: role aet_hub_app, usada pela API em runtime (RLS ativa).
# - AUTH_DATABASE_URL: role aet_hub_auth, usada só pelo módulo de auth
#   (lookup de username no login e criação de conta no cadastro).
MIGRATE_DATABASE_URL="postgresql://aet_hub_owner:defina-uma-senha-forte-aqui@localhost:5432/aet_hub?schema=public"
DATABASE_URL="postgresql://aet_hub_app:defina-uma-senha-forte-aqui@localhost:5432/aet_hub?schema=public"
AUTH_DATABASE_URL="postgresql://aet_hub_auth:defina-uma-senha-forte-aqui@localhost:5432/aet_hub?schema=public"

# API
PORT=3333
NODE_ENV=development

# Autenticação
JWT_SECRET="defina-um-segredo-forte-aqui"
JWT_EXPIRES_IN="1d"

# Frontend
VITE_API_URL="http://localhost:3333"

# Armazenamento de fotos de torneio (RF-15), relativo ao cwd do processo
# da API (apps/api quando rodado via npm workspace).
UPLOAD_DIR="uploads"
